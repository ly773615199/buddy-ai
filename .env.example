# Buddy 后端环境变量
# 复制为 .env 并填入实际值

# ===== 统一模型池（推荐） =====
# 只需填 API Key，系统自动发现可用模型
# 支持同时配置多个 Provider，自动选择最优模型

# OpenAI / GPT
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# SiliconFlow 硅基流动 (https://cloud.siliconflow.cn)
SILICONFLOW_API_KEY=

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Google / Gemini
GOOGLE_API_KEY=

# ===== 搜索工具 =====
# Brave Search API Key (https://brave.com/search/api/)
BRAVE_API_KEY=
# Serper API Key (https://serper.dev/)
SERPER_API_KEY=

# ===== TTS =====
# Edge TTS 无需配置（默认免费）
# Azure Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ===== 其他 =====
# WS 服务器端口（默认 8765）
# BUDDY_WS_PORT=8765
# 沙箱工作目录
# BUDDY_SANDBOX_DIR=/tmp/buddy-sandbox

# ===== 自适应并发控制 =====
# 起步并发数（默认 3，算法从这里开始调整）
# BUDDY_MAX_CONCURRENT=3
# 最大等待时间 ms（默认 60000）
# BUDDY_TASK_QUEUE_WAIT_MS=60000
# 单条消息最大处理时间 ms（默认 120000）
# BUDDY_PROCESSING_TIMEOUT_MS=120000
# 禁用自适应（回退到固定并发数）
# BUDDY_ADAPTIVE_ENABLED=false
# 最小并发数（默认 1）
# BUDDY_ADAPTIVE_MIN=1
# 最大并发数（默认根据 API provider 自动计算）
# BUDDY_ADAPTIVE_MAX=10

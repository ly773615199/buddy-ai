{
  "compilerOptions": {
    "rootDir": "./src",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "files": ["frontend/src/types/browser-apis.d.ts"],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/test-week*.test.ts"]
}

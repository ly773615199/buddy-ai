{
  "name": "audio_info",
  "description": "获取音频文件的元数据信息，包括时长、编码格式、采样率等",
  "author": "buddy",
  "version": "1.0.0",
  "tags": ["媒体", "音频", "元数据", "ffprobe"],
  "permission": "exec_safe",
  "parameters": [
    {
      "name": "file",
      "type": "string",
      "description": "音频文件路径",
      "required": true
    }
  ],
  "execute": "ffprobe -v quiet -print_format json -show_format '${file}'",
  "timeout": 10,
  "resultParser": "json"
}

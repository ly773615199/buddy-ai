{
  "name": "disk_usage",
  "description": "分析磁盘空间使用情况",
  "permission": "exec_safe",
  "author": "buddy",
  "version": "1.0.0",
  "parameters": {
    "path": {
      "type": "string",
      "required": false,
      "default": "/",
      "description": "分析路径"
    }
  },
  "execute": {
    "command": "du -h --max-depth=1 / 2>/dev/null | sort -rh | head -20",
    "timeout": 15
  },
  "resultParser": "lines",
  "tags": ["运维", "磁盘", "存储"]
}

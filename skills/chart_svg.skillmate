{
  "name": "chart_svg",
  "description": "生成 SVG 图表：柱状图、折线图、饼图、散点图",
  "version": "1.0.0",
  "author": "buddy",
  "tags": ["图表", "可视化", "SVG"],
  "permission": "exec_safe",
  "parameters": {
    "type": {
      "type": "string",
      "description": "图表类型：bar(柱状图) / line(折线图) / pie(饼图) / scatter(散点图)",
      "required": true,
      "enum": ["bar", "line", "pie", "scatter"]
    },
    "data": {
      "type": "string",
      "description": "数据，格式：label1:value1,label2:value2,... 或 JSON 数组",
      "required": true
    },
    "title": {
      "type": "string",
      "description": "图表标题",
      "required": false
    },
    "width": {
      "type": "number",
      "description": "图表宽度",
      "required": false,
      "default": 600
    },
    "height": {
      "type": "number",
      "description": "图表高度",
      "required": false,
      "default": 400
    },
    "output": {
      "type": "string",
      "description": "输出文件路径，默认输出到 stdout",
      "required": false
    }
  },
  "execute": {
    "command": "python3 -c \"\nimport sys, json, math\ntype_='${type}'\ndata_str='${data}'\ntitle='${title}' or ''\nwidth=int('${width}' or 600)\nheight=int('${height}' or 400)\noutput='${output}' or ''\n\n# Parse data\ntry:\n    items = json.loads(data_str)\n    if isinstance(items, list) and all(isinstance(i, dict) for i in items):\n        labels = [str(i.get('label', i.get('name', ''))) for i in items]\n        values = [float(i.get('value', i.get('y', 0))) for i in items]\n    elif isinstance(items, list) and all(isinstance(i, (list,tuple)) for i in items):\n        labels = [str(i[0]) for i in items]\n        values = [float(i[1]) for i in items]\n    else:\n        labels = [str(i) for i in range(len(items))]\n        values = [float(v) for v in items]\nexcept:\n    parts = [p.strip() for p in data_str.split(',')]\n    labels, values = [], []\n    for p in parts:\n        if ':' in p:\n            k, v = p.split(':', 1)\n            labels.append(k.strip())\n            values.append(float(v.strip()))\n        else:\n            labels.append(str(len(labels)))\n            values.append(float(p))\n\nif not labels:\n    print('无数据'); sys.exit(1)\n\n# Colors\nCOLORS = ['#4e79a7','#f28e2b','#e15759','#76b7b2','#59a14f','#edc948','#b07aa1','#ff9da7','#9c755f','#bab0ac']\nsvg_parts = []\nmargin = 60\nchart_w = width - margin * 2\nchart_h = height - margin * 2\n\nsvg_parts.append(f'<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{width}\" height=\"{height}\" style=\"font-family:Arial,sans-serif\">')\nsvg_parts.append(f'<rect width=\"{width}\" height=\"{height}\" fill=\"white\"/>')\n\nif title:\n    svg_parts.append(f'<text x=\"{width//2}\" y=\"30\" text-anchor=\"middle\" font-size=\"16\" font-weight=\"bold\">{title}</text>')\n\nif type_ == 'bar':\n    max_v = max(values) if values else 1\n    bar_w = chart_w / len(labels) * 0.7\n    gap = chart_w / len(labels) * 0.3\n    for i, (l, v) in enumerate(zip(labels, values)):\n        x = margin + i * (bar_w + gap) + gap/2\n        h = (v / max_v) * chart_h if max_v > 0 else 0\n        y = margin + chart_h - h\n        color = COLORS[i % len(COLORS)]\n        svg_parts.append(f'<rect x=\"{x}\" y=\"{y}\" width=\"{bar_w}\" height=\"{h}\" fill=\"{color}\" rx=\"2\"/>')\n        svg_parts.append(f'<text x=\"{x+bar_w/2}\" y=\"{margin+chart_h+20}\" text-anchor=\"middle\" font-size=\"11\">{l[:8]}</text>')\n        svg_parts.append(f'<text x=\"{x+bar_w/2}\" y=\"{y-5}\" text-anchor=\"middle\" font-size=\"10\">{v:.1f}</text>')\n\nelif type_ == 'line':\n    max_v = max(values) if values else 1\n    min_v = min(values) if values else 0\n    rng = max_v - min_v if max_v != min_v else 1\n    points = []\n    for i, (l, v) in enumerate(zip(labels, values)):\n        x = margin + i * chart_w / (len(labels)-1) if len(labels) > 1 else margin + chart_w/2\n        y = margin + chart_h - ((v - min_v) / rng) * chart_h\n        points.append(f'{x},{y}')\n        svg_parts.append(f'<circle cx=\"{x}\" cy=\"{y}\" r=\"4\" fill=\"{COLORS[0]}\"/>')\n        svg_parts.append(f'<text x=\"{x}\" y=\"{margin+chart_h+20}\" text-anchor=\"middle\" font-size=\"11\">{l[:8]}</text>')\n    svg_parts.append(f'<polyline points=\"{\" \".join(points)}\" fill=\"none\" stroke=\"{COLORS[0]}\" stroke-width=\"2\"/>')\n\nelif type_ == 'pie':\n    total = sum(values) if values else 1\n    cx, cy, r = width//2, margin + chart_h//2 + 10, min(chart_w, chart_h) // 2 - 20\n    angle = -90\n    for i, (l, v) in enumerate(zip(labels, values)):\n        sweep = v / total * 360\n        x1 = cx + r * math.cos(math.radians(angle))\n        y1 = cy + r * math.sin(math.radians(angle))\n        x2 = cx + r * math.cos(math.radians(angle + sweep))\n        y2 = cy + r * math.sin(math.radians(angle + sweep))\n        large = 1 if sweep > 180 else 0\n        color = COLORS[i % len(COLORS)]\n        svg_parts.append(f'<path d=\"M{cx},{cy} L{x1},{y1} A{r},{r} 0 {large},1 {x2},{y2} Z\" fill=\"{color}\" stroke=\"white\" stroke-width=\"2\"/>')\n        mid_angle = math.radians(angle + sweep/2)\n        lx = cx + r*0.65 * math.cos(mid_angle)\n        ly = cy + r*0.65 * math.sin(mid_angle)\n        svg_parts.append(f'<text x=\"{lx}\" y=\"{ly}\" text-anchor=\"middle\" font-size=\"10\" fill=\"white\">{l[:6]}</text>')\n        angle += sweep\n\nelif type_ == 'scatter':\n    if len(values) < 2:\n        print('散点图需要至少2个数据点'); sys.exit(1)\n    max_v = max(values)\n    min_v = min(values)\n    rng = max_v - min_v if max_v != min_v else 1\n    for i, (l, v) in enumerate(zip(labels, values)):\n        x = margin + (i / (len(values)-1)) * chart_w if len(values) > 1 else margin + chart_w/2\n        y = margin + chart_h - ((v - min_v) / rng) * chart_h\n        color = COLORS[i % len(COLORS)]\n        svg_parts.append(f'<circle cx=\"{x}\" cy=\"{y}\" r=\"6\" fill=\"{color}\" opacity=\"0.7\"/>')\n        svg_parts.append(f'<text x=\"{x}\" y=\"{y-10}\" text-anchor=\"middle\" font-size=\"9\">{l[:6]}</text>')\n\nsvg_parts.append('</svg>')\nsvg = '\\n'.join(svg_parts)\nif output:\n    with open(output, 'w') as f: f.write(svg)\n    print(f'SVG 已保存到 {output}')\nelse:\n    print(svg)\n\" 2>&1",
    "timeout": 15
  },
  "resultParser": "text"
}

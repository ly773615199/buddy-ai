{
  "name": "github_info",
  "description": "查看 GitHub 仓库基本信息（星标数、语言、描述等）",
  "version": "1.0.0",
  "author": "buddy",
  "tags": ["github", "开发", "代码"],
  "permission": "exec_safe",
  "parameters": {
    "repo": {
      "type": "string",
      "description": "仓库名，格式 owner/repo，如 facebook/react",
      "required": true
    }
  },
  "execute": {
    "command": "curl -s 'https://api.github.com/repos/${repo}' --max-time 10 | python3 -c \"import sys,json; d=json.load(sys.stdin); print(f'仓库: {d.get(\\\"full_name\\\",\\\"未知\\\")}\\n描述: {d.get(\\\"description\\\",\\\"无\\\")}\\n语言: {d.get(\\\"language\\\",\\\"未知\\\")}\\n星标: {d.get(\\\"stargazers_count\\\",0)}\\nFork: {d.get(\\\"forks_count\\\",0)}\\n许可: {d.get(\\\"license\\\",{}).get(\\\"spdx_id\\\",\\\"无\\\") if d.get(\\\"license\\\") else \\\"无\\\"}')\"",
    "timeout": 15
  },
  "resultParser": "text"
}
